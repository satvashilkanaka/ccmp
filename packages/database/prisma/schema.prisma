// ── Generator & Datasource ────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  AGENT
  SENIOR_AGENT
  SUPERVISOR
  QA_ANALYST
  OPERATIONS_MANAGER
  COMPLIANCE_OFFICER
  ADMIN
}

enum CaseStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  ESCALATED
  PENDING_CLOSURE
  RESOLVED
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseChannel {
  PHONE
  EMAIL
  CHAT
  SOCIAL
  WALK_IN
}

enum AgentPresence {
  ONLINE
  BUSY
  AWAY
  OFFLINE
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid()) @map("id")
  email     String    @unique @map("email")
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  role      UserRole  @map("role")
  teamId    String?   @map("team_id")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  team                  Team?                   @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  cases                 Case[]                  @relation("AssignedCases")
  events                CaseEvent[]             @relation("EventActor")
  qaReviews             QaReview[]              @relation("QaReviewer")
  caseNotes             CaseNote[]              @relation("NoteAuthor")
  attachments           Attachment[]            @relation("AttachmentUploader")
  kbArticles            KbArticle[]             @relation("ArticleAuthor")
  notificationPreference NotificationPreference? @relation("UserNotificationPreference")

  @@map("users")
}

model Team {
  id           String    @id @default(cuid()) @map("id")
  name         String    @unique @map("name")
  description  String?   @map("description")
  supervisorId String?   @map("supervisor_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  members User[]  @relation("TeamMembers")
  cases   Case[]  @relation("TeamCases")

  @@map("teams")
}

model Case {
  id             String       @id @default(cuid()) @map("id")
  caseNumber     String       @unique @map("case_number")
  subject        String       @map("subject")
  description    String?      @map("description")
  status         CaseStatus   @default(NEW) @map("status")
  priority       CasePriority @default(MEDIUM) @map("priority")
  channel        CaseChannel  @map("channel")
  customerId     String?      @map("customer_id")
  customerEmail  String?      @map("customer_email")
  customerPhone  String?      @map("customer_phone")
  assignedToId   String?      @map("assigned_to_id")
  teamId         String?      @map("team_id")
  queueId        String?      @map("queue_id")
  slaPolicyId    String?      @map("sla_policy_id")
  slaDueAt       DateTime?    @map("sla_due_at")
  slaBreachedAt  DateTime?    @map("sla_breached_at")
  metadata       Json         @default("{}") @map("metadata")
  version        Int          @default(1) @map("version")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  assignedTo   User?          @relation("AssignedCases", fields: [assignedToId], references: [id], onDelete: SetNull)
  team         Team?          @relation("TeamCases", fields: [teamId], references: [id], onDelete: SetNull)
  queue        Queue?         @relation("QueueCases", fields: [queueId], references: [id], onDelete: SetNull)
  slaPolicy    SlaPolicy?     @relation("SlaPolicyCases", fields: [slaPolicyId], references: [id], onDelete: SetNull)
  events       CaseEvent[]    @relation("CaseEvents")
  notes        CaseNote[]     @relation("CaseNotes")
  attachments  Attachment[]   @relation("CaseAttachments")
  recordings   Recording[]    @relation("CaseRecordings")
  qaReviews    QaReview[]     @relation("CaseQaReviews")
  csatResponse CsatResponse?  @relation("CaseCsat")

  @@index([status])
  @@index([assignedToId])
  @@index([teamId])
  @@index([createdAt])
  @@index([slaDueAt])
  @@map("cases")
}

model CaseEvent {
  id        String   @id @default(cuid()) @map("id")
  caseId    String   @map("case_id")
  eventType String   @map("event_type")
  payload   Json     @default("{}") @map("payload")
  actorId   String?  @map("actor_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  case  Case  @relation("CaseEvents", fields: [caseId], references: [id], onDelete: Cascade)
  actor User? @relation("EventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([eventType])
  @@map("case_events")
}

model CaseNote {
  id         String   @id @default(cuid()) @map("id")
  caseId     String   @map("case_id")
  content    String   @map("content")
  authorId   String   @map("author_id")
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  case   Case @relation("CaseNotes", fields: [caseId], references: [id], onDelete: Cascade)
  author User @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([caseId])
  @@map("case_notes")
}

model Attachment {
  id           String   @id @default(cuid()) @map("id")
  caseId       String   @map("case_id")
  filename     String   @map("filename")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  storageKey   String   @map("storage_key")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  case       Case @relation("CaseAttachments", fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([caseId])
  @@map("attachments")
}

model Queue {
  id          String   @id @default(cuid()) @map("id")
  name        String   @unique @map("name")
  description String?  @map("description")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  cases Case[] @relation("QueueCases")

  @@map("queues")
}

model SlaPolicy {
  id                    String       @id @default(cuid()) @map("id")
  name                  String       @map("name")
  priority              CasePriority @map("priority")
  channel               CaseChannel  @map("channel")
  responseTimeMinutes   Int          @map("response_time_minutes")
  resolutionTimeMinutes Int          @map("resolution_time_minutes")
  warningThresholdPct   Float        @default(0.8) @map("warning_threshold_pct")
  isActive              Boolean      @default(true) @map("is_active")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  // Relations
  cases Case[] @relation("SlaPolicyCases")

  @@unique([priority, channel])
  @@map("sla_policies")
}

model RoutingRule {
  id            String   @id @default(cuid()) @map("id")
  name          String   @map("name")
  conditions    Json     @map("conditions")
  actions       Json     @map("actions")
  priorityOrder Int      @map("priority_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([priorityOrder])
  @@map("routing_rules")
}

model Recording {
  id                  String    @id @default(cuid()) @map("id")
  caseId              String    @map("case_id")
  callUuid            String    @unique @map("call_uuid")
  filename            String    @map("filename")
  storageKey          String    @map("storage_key")
  durationSeconds     Int?      @map("duration_seconds")
  fileSizeBytes       Int?      @map("file_size_bytes")
  encryptionAlgorithm String    @default("AES256") @map("encryption_algorithm")
  isPaused            Boolean   @default(false) @map("is_paused")
  retentionExpiresAt  DateTime? @map("retention_expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  case Case @relation("CaseRecordings", fields: [caseId], references: [id], onDelete: Restrict)

  @@index([caseId])
  @@map("recordings")
}

model QaReview {
  id              String   @id @default(cuid()) @map("id")
  caseId          String   @map("case_id")
  reviewerId      String   @map("reviewer_id")
  scores          Json     @map("scores")
  totalScore      Float    @map("total_score")
  complianceFlags String[] @default([]) @map("compliance_flags")
  coachingNotes   String?  @map("coaching_notes")
  reviewedAt      DateTime @default(now()) @map("reviewed_at")

  // Relations
  case     Case @relation("CaseQaReviews", fields: [caseId], references: [id], onDelete: Restrict)
  reviewer User @relation("QaReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([caseId])
  @@index([reviewerId])
  @@map("qa_reviews")
}

model AuditLog {
  id           String   @id @default(cuid()) @map("id")
  actorId      String?  @map("actor_id")
  actorEmail   String?  @map("actor_email")
  action       String   @map("action")
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  payload      Json     @default("{}") @map("payload")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  // No updatedAt — append-only by design
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model CsatResponse {
  id          String    @id @default(cuid()) @map("id")
  caseId      String    @unique @map("case_id")
  token       String    @unique @map("token")
  score       Int       @map("score")
  feedback    String?   @map("feedback")
  submittedAt DateTime? @map("submitted_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  case Case @relation("CaseCsat", fields: [caseId], references: [id], onDelete: Cascade)

  @@map("csat_responses")
}

model KbArticle {
  id          String    @id @default(cuid()) @map("id")
  title       String    @map("title")
  content     String    @map("content")
  category    String    @map("category")
  tags        String[]  @default([]) @map("tags")
  authorId    String    @map("author_id")
  viewCount   Int       @default(0) @map("view_count")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  author User @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([category])
  @@index([isPublished])
  @@map("kb_articles")
}

model NotificationPreference {
  id                 String   @id @default(cuid()) @map("id")
  userId             String   @unique @map("user_id")
  emailOnAssign      Boolean  @default(true) @map("email_on_assign")
  emailOnSlaWarning  Boolean  @default(true) @map("email_on_sla_warning")
  emailOnSlaBreach   Boolean  @default(true) @map("email_on_sla_breach")
  emailOnQaReview    Boolean  @default(false) @map("email_on_qa_review")
  emailDailySummary  Boolean  @default(true) @map("email_daily_summary")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation("UserNotificationPreference", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
