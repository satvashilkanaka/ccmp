# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL superuser login used by Docker and Prisma
POSTGRES_USER=ccmp_user
# Strong password for the PostgreSQL user — change before first run
POSTGRES_PASSWORD=CHANGE_ME_strong_password
# Name of the primary application database
POSTGRES_DB=ccmp
# Primary (read-write) connection string via PgBouncer (port 6432)
DATABASE_URL=postgresql://ccmp_user:CHANGE_ME_strong_password@localhost:6432/ccmp
# Read-replica connection string for analytics/reporting queries (port 5433)
DATABASE_READ_URL=postgresql://ccmp_user:CHANGE_ME_strong_password@localhost:5433/ccmp

# ── Redis ────────────────────────────────────────────────────────────────────
# Password for Redis AUTH — must match the value set in redis.conf
REDIS_PASSWORD=CHANGE_ME_redis_password
# Full Redis connection URL used by BullMQ, Socket.IO adapter, and cache layer
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379

# ── Keycloak ─────────────────────────────────────────────────────────────────
# Username of the Keycloak master-realm admin console account
KEYCLOAK_ADMIN=admin
# Password for the Keycloak admin account
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin
# Base URL of the Keycloak server (used by the API for JWKS / token validation)
KEYCLOAK_URL=http://localhost:8180
# Keycloak realm that contains all CCMP users and clients
KEYCLOAK_REALM=ccmp
# Client ID of the machine-to-machine service account registered in Keycloak
KEYCLOAK_API_CLIENT_ID=ccmp-api
# Client secret for the ccmp-api service account
KEYCLOAK_API_SECRET=CHANGE_ME_client_secret

# ── MinIO ────────────────────────────────────────────────────────────────────
# Root (admin) access key for MinIO — equivalent to AWS_ACCESS_KEY_ID
MINIO_ROOT_USER=ccmp_admin
# Root secret key for MinIO — equivalent to AWS_SECRET_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
# Hostname of the MinIO server (without protocol)
MINIO_ENDPOINT=localhost
# MinIO S3-API port (console runs on 9001)
MINIO_PORT=9000
# Set to true when MinIO is behind TLS termination (e.g., Traefik with certs)
MINIO_USE_SSL=false
# Bucket name where call recordings are stored
MINIO_RECORDINGS_BUCKET=ccmp-recordings

# ── Meilisearch ───────────────────────────────────────────────────────────────
# Master key that protects the Meilisearch admin API — minimum 16 chars
MEILI_MASTER_KEY=CHANGE_ME_32_char_minimum_key_here
# Base URL used by the API to query Meilisearch
MEILI_URL=http://localhost:7700

# ── Application ───────────────────────────────────────────────────────────────
# Runtime environment; controls logging verbosity and error detail level
NODE_ENV=development
# Port the Express API server listens on
API_PORT=4000
# Public-facing API URL consumed by the Next.js frontend (must be reachable from browser)
NEXT_PUBLIC_API_URL=http://localhost:4000
# WebSocket server URL consumed by the frontend to connect Socket.IO
NEXT_PUBLIC_WS_URL=http://localhost:4000
# Comma-separated list of allowed CORS origins for the API
ALLOWED_ORIGINS=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────────────────────
# Fallback HS256 signing secret if Keycloak is unavailable — minimum 32 chars
JWT_SECRET=CHANGE_ME_jwt_fallback_secret_min_32_chars

# ── Phase 2+ (fill in when reaching those weeks) ──────────────────────────────
# Hostname of the FreeSWITCH server for ESL (Event Socket Layer) connections
FREESWITCH_HOST=localhost
# Port number for the FreeSWITCH ESL interface
FREESWITCH_ESL_PORT=8021
# Password for the FreeSWITCH ESL interface (default: ClueCon — change in prod)
FREESWITCH_ESL_PASSWORD=ClueCon
# Number of days to retain call recordings before automatic deletion
RECORDING_RETENTION_DAYS=90

# ── Phase 3+ ─────────────────────────────────────────────────────────────────
# RSA private key (PEM) used to sign tamper-evident audit-log exports
AUDIT_EXPORT_PRIVATE_KEY=
# Secret used to sign/verify CSAT survey tokens — minimum 32 chars
CSAT_TOKEN_SECRET=CHANGE_ME_csat_secret_min_32_chars

# ── Phase 4+ ─────────────────────────────────────────────────────────────────
# Password for the PostgreSQL streaming replication slot user
REPLICATION_PASSWORD=CHANGE_ME_replication_password

# ── Phase 5+ ─────────────────────────────────────────────────────────────────
# Hostname of the outbound SMTP relay (e.g. Mailgun, SendGrid, SES)
SMTP_HOST=smtp.mailgun.org
# SMTP submission port (587 = STARTTLS, 465 = SMTPS)
SMTP_PORT=587
# SMTP authentication username / API key login
SMTP_USER=postmaster@yourdomain.com
# SMTP authentication password / API key
SMTP_PASSWORD=CHANGE_ME_smtp_password
# "From" address that appears on all system-generated emails
EMAIL_FROM=noreply@yourdomain.com
